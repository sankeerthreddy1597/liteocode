{
  "name": "@litecode/server",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "postinstall": "bun run --cwd ../database db:generate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/openai": "^3.0.67",
    "@ai-sdk/provider-utils": "^4.0.27",
    "@hono/zod-validator": "^0.8.0",
    "@litecode/database": "workspace:*",
    "@litecode/shared": "workspace:*",
    "@sentry/bun": "^10.55.0",
    "@sentry/hono": "^10.55.0",
    "@types/bun": "^1.3.14",
    "ai": "^6.0.193",
    "dotenv": "^17.4.2",
    "hono": "^4.12.21",
    "zod": "^4.4.3"
  }
}
